# ============================================================
# AI RECEPTIONIST - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your real keys
# ============================================================

# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...your-service-role-key
ANTHROPIC_API_KEY=sk-ant-api03-...your-key

# Server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Vapi (optional — only for phone integration)
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=

# Limits
MAX_CONCURRENT_AI_CALLS=10
RATE_LIMIT_CHAT=30
RATE_LIMIT_VAPI=60

# Logging
LOG_LEVEL=info
